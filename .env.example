# ─────────────────────────────────────────────────────────────
#  Supabase
# ─────────────────────────────────────────────────────────────
# Project ref is lkbscrsgoxvetbtvbles -> URL is https://<ref>.supabase.co
SUPABASE_URL=https://lkbscrsgoxvetbtvbles.supabase.co
# Service role key (Project Settings -> API). Used server-side only. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
#  Apify
# ─────────────────────────────────────────────────────────────
# Personal API token from https://console.apify.com/account/integrations
APIFY_TOKEN=your-apify-token
# Actor IDs to run.
APIFY_INSTAGRAM_ACTOR=apify/instagram-post-scraper
APIFY_INSTAGRAM_PROFILE_ACTOR=apify/instagram-profile-scraper
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
# Max posts to pull per account per run. Apify charges ~$1.70 / 1000 posts,
# so keep this small (accounts rarely post >10 times between Mon and Fri).
APIFY_RESULTS_LIMIT=10
APIFY_FACEBOOK_RESULTS_LIMIT=20
APIFY_ACTOR_WAIT_SECS=240
# The IG Profile Scraper is pricey (~$2.60 / 100 profiles). Only refresh an
# account's follower count when the cached value is older than this many days.
# Set to 0 to refresh every run.
FOLLOWER_REFRESH_DAYS=7
# Only keep posts whose caption/hashtags mention one of these keywords
# (comma-separated, matched ignoring case/spaces/punctuation so "Arthur's
# Jewelers", "@arthursjewelers", "#ArthursJewelers" and "arthursjewelers.com"
# all match). Leave empty to keep every post.
TRACK_KEYWORDS=ChildrensMNPartner

# ─────────────────────────────────────────────────────────────
#  Scheduling (worker)
# ─────────────────────────────────────────────────────────────
# Cron expression. Default: 09:00 every Monday and Friday.
SCRAPE_CRON=0 9 * * 1,5
# Timezone for the cron schedule.
TZ=America/Chicago
# Set to "true" to run a scrape immediately when the worker boots (useful for testing).
RUN_ON_BOOT=false

# ─────────────────────────────────────────────────────────────
#  Security
# ─────────────────────────────────────────────────────────────
# Shared secret required to trigger POST /api/scrape (Authorization: Bearer <secret>).
CRON_SECRET=change-me-to-a-long-random-string
# Optional HTTP Basic Auth for the dashboard. Leave both blank to disable.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
